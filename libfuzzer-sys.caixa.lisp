   :body "[package]\nname = \"example\"\nversion = \"0.1.0\"\nauthors = [\"Simonas Kazlauskas <git@kazlauskas.me>\"]\nedition = \"2018\"\n\n[workspace]\nmembers = [\".\"]\n\n[dependencies]\nlibfuzzer-sys = { path = \"..\" }\n"} {:path "example/src/main.rs"
   :sha256 "d46ebfbefced0f91d9990d3aab7ff1bdcc09b2a8850d6e75e6b0cf64766f8776"

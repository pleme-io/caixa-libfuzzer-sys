   :size 247
   :body "#!/bin/bash -ex\n\nproject_dir=\"$(pwd)\"\ntmp_dir=\"$(mktemp -d)\"\n\ngit clone https://github.com/llvm-mirror/compiler-rt.git \"$tmp_dir\"\ncd \"$tmp_dir\"\ngit checkout \"$1\"\nrm -rf \"$project_dir/libfuzzer/\"\nmv \"$tmp_dir/lib/fuzzer/\" \"$project_dir/libfuzzer/\"\n"} {:path ".gitignore"
